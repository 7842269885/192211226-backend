# Growsmart Backend Configuration Template
# Copy this file to .env and fill in the values

# --- Database ---
DB_CONNECTION_STRING="Server=localhost;Database=growsmart_db;User=root;Password=YOUR_PASSWORD_HERE;"

# --- AI Services ---
GOOGLE_GEMINI_API_KEY="AIzaSy..." # Get from https://aistudio.google.com/
PLANT_ID_API_KEY="YOUR_KEY_HERE"

# --- Email (SMTP) ---
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# --- App Settings ---
ASPNETCORE_ENVIRONMENT="Development"
PORT=5050
